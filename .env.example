# ============================================
#  StreamApp — Environment Variables
#  Copy to .env for local development
# ============================================

# --- Backend (Render / local server) ---
PORT=3001

# Your Vercel production URL (no trailing slash) — required for CORS on Render
FRONTEND_URL=https://your-app.vercel.app

# API keys (backend only — never expose in Vercel VITE_* except public URLs)
OMDB_API_KEY=
TMDB_API_KEY=
YOUTUBE_API_KEY=
# Full HD poster/backdrop fallback when TMDB/IMDb images are missing (https://unsplash.com/developers)
UNSPLASH_APPLICATION_ID=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Set true only if serving built frontend from Express (single-server deploy)
SERVE_STATIC=false

# --- Frontend (Vercel) — set in Vercel Dashboard → Environment Variables ---
# Render API URL (no trailing slash). Leave empty for local dev (Vite proxy).
# VITE_API_URL=https://streamapp-api.onrender.com
